# n8n Webhook URL - your workflow must accept POST with { message, sessionId } and respond with JSON (e.g. { reply: "..." })
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-path

# Server port (default: 3000)
PORT=3000

# JWT secret used to sign the token sent to the n8n webhook (required)
JWT_SECRET=your-secret-here
